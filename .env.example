# ── WHITESPACE configuration ───────────────────────────────────────────────
# Copy to .env and fill in. Keys are read from this file at startup (dotenv).

# LLM providers — resilient chain (Claude primary → Groq → OpenAI).
# At minimum set ANTHROPIC_API_KEY (vision deconstruction needs Claude).
ANTHROPIC_API_KEY=
GROQ_API_KEY=
OPENAI_API_KEY=

# Model ids (override only if needed)
WHITESPACE_CLAUDE_MODEL=claude-sonnet-4-6
WHITESPACE_CLAUDE_VISION_MODEL=claude-sonnet-4-6
WHITESPACE_GROQ_MODEL=llama-3.3-70b-versatile
WHITESPACE_OPENAI_MODEL=gpt-4o-mini

# Bright Data — live public ad-market recon (Web Unlocker + Scraping Browser).
# Same token/zone shape as the AIdeazz fleet's brightdata-enrich layer.
BRIGHTDATA_API_TOKEN=
BRIGHTDATA_ZONE=

# Server
PORT=8095

# Run controls (sane defaults; override to spend more/less per run)
WHITESPACE_MAX_CREATIVES=12
WHITESPACE_MAX_TOOL_CALLS=10
WHITESPACE_RUN_TIMEOUT_MS=180000
