# ── WHITESPACE configuration ───────────────────────────────────────────────
# Copy to .env and fill in. Keys are read from this file at startup (dotenv).

# LLM providers — resilient chain (Claude primary → Groq → OpenAI).
# At minimum set ANTHROPIC_API_KEY (vision deconstruction needs Claude).
# 4-tier failover: Claude -> Groq -> OpenAI -> Grok (any single outage survivable).
ANTHROPIC_API_KEY=
GROQ_API_KEY=
OPENAI_API_KEY=
XAI_API_KEY=

# Model ids (override only if needed)
WHITESPACE_CLAUDE_MODEL=claude-sonnet-4-6
WHITESPACE_CLAUDE_VISION_MODEL=claude-sonnet-4-6
WHITESPACE_GROQ_MODEL=llama-3.3-70b-versatile
WHITESPACE_OPENAI_MODEL=gpt-4o-mini
WHITESPACE_GROK_MODEL=grok-3

# Bright Data — live public ad-market recon
# Web Unlocker (fleet default): BRIGHTDATA_ZONE=web_unlocker1
BRIGHTDATA_API_TOKEN=
BRIGHTDATA_ZONE=
# Scraping Browser zone (recommended for Meta Ad Library): brd-customer-XXX-zone-NAME:password
# Create at brightdata.com → Scraping Browser → zone Overview tab
BRIGHTDATA_BROWSER_AUTH=

# Meta Ad Library Graph API (optional — US commercial ads still need browser scrape above)
# Apply at developers.facebook.com → Ads Library API product
META_AD_LIBRARY_ACCESS_TOKEN=
META_GRAPH_VERSION=v21.0
META_API_COUNTRIES=US

# Meta fetch resilience (defaults: 90s timeout, 3 retries, 4s between Meta calls, 5s between verticals)
WHITESPACE_META_FETCH_TIMEOUT_MS=90000
WHITESPACE_META_FETCH_RETRIES=3
WHITESPACE_META_FETCH_PAUSE_MS=4000
WHITESPACE_META_VERTICAL_PAUSE_MS=5000

# Server
PORT=8095
ATLAS_PUBLIC_BASE=https://webhook.aideazz.xyz/whitespace

# Creative ship (Generate creative button on atlas.html)
REPLICATE_API_TOKEN=
RUNWAY_API_KEY=
LUMA_API_KEY=
# Google video (additive fallbacks after Runway/Luma) — same key as Atuona Veo
GEMINI_API_KEY=
# GOOGLE_API_KEY=   # alias accepted
# GEMINI_OMNI_MODEL=gemini-omni-flash-preview
# GOOGLE_VIDEO_OMNI_ONLY=1   # Atlas Google path: Omni Flash only (skip Veo fallback)
# VEO_MODEL=veo-3.1-generate-preview
# Optional — when set, /api/atlas/ship requires ?token= (use ?ship_token= in atlas URL)
ATLAS_SHIP_TOKEN=

# AIdeazz performance bridge (CTO AIPA Oracle ledger — read outcomes in Atlas UI)
ATLAS_PERFORMANCE_HUB_URL=https://webhook.aideazz.xyz/cto/api/atlas-performance
ATLAS_PERFORMANCE_SECRET=
# Same value as OUTREACH_SECRET on CTO AIPA (whitespace .env on Oracle)
# ATLAS_LANDING_BASE=https://aideazz.xyz
# ATLAS_PERFORMANCE_INGEST_URL=https://webhook.aideazz.xyz/cto/api/performance-event

# Telegram — daily brief push (fleet token; send-only — no conflict with CTO AIPA polling)
# Falls back: ATLAS_* → TELEGRAM_BOT_TOKEN + TELEGRAM_LEADS_DIGEST_CHAT_ID
ATLAS_TELEGRAM_BOT_TOKEN=
ATLAS_TELEGRAM_CHAT_ID=
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_LEADS_DIGEST_CHAT_ID=

# Run controls (sane defaults; override to spend more/less per run)
WHITESPACE_MAX_CREATIVES=12
WHITESPACE_MAX_TOOL_CALLS=10
WHITESPACE_RUN_TIMEOUT_MS=180000
